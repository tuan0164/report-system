# Thông tin DB cho docker-compose.prod.yml.
# Copy thành .env ở CÙNG thư mục này (.env đã nằm trong .gitignore, không commit).
#
# Sinh mật khẩu mạnh:
#   openssl rand -hex 24
#
# Đây là nguồn DUY NHẤT của mật khẩu DB. Compose tự dựng DATABASE_URL cho
# backend từ 3 biến dưới, nên KHÔNG đặt lại DATABASE_URL trong report_be/.env.
POSTGRES_USER=webapp
POSTGRES_PASSWORD=
POSTGRES_DB=report

# --- Rate limit route đăng nhập (/api/auth/) ---
# Tính theo IP mà nginx nhìn thấy. Nếu cả văn phòng ra Internet qua một IP NAT
# chung thì đây là ngưỡng cho TOÀN CÔNG TY, không phải cho từng người.
# Thực tế giờ cao điểm chỉ ~3-5 req/phút -> 60r/m đã thoải mái gấp hơn 10 lần,
# mà vẫn cắt được flood hàng nghìn req/giây.
#   AUTH_RATE  : số request/phút duy trì (vd 60r/m, 120r/m)
#   AUTH_BURST : số request cho dồn tức thời trước khi bị siết
# Sửa xong chỉ cần: docker compose -f docker-compose.prod.yml up -d frontend
AUTH_RATE=60r/m
AUTH_BURST=100

# LƯU Ý: đổi POSTGRES_PASSWORD ở đây KHÔNG đổi mật khẩu của volume đã tồn tại.
# Postgres chỉ đọc biến này lúc khởi tạo volume lần đầu. Với DB đang chạy:
#   docker compose -f docker-compose.prod.yml exec postgres \
#     psql -U webapp -d report -c "ALTER USER webapp WITH PASSWORD '<mật khẩu mới>';"
# rồi mới recreate backend để nó dùng mật khẩu mới.
