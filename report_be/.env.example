# Google OAuth — tạo tại https://console.cloud.google.com
# Authorized redirect URI phải là: <BACKEND_URL>/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Sinh MỚI cho mỗi môi trường, không dùng lại giữa dev và prod:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# Đổi JWT_SECRET_KEY sẽ vô hiệu mọi phiên đăng nhập hiện có.
JWT_SECRET_KEY=
SESSION_SECRET_KEY=

# Không có dấu / ở cuối.
FRONTEND_URL=https://your-domain.com
BACKEND_URL=https://your-domain.com/api

# DATABASE_URL KHÔNG đặt ở đây. docker-compose.prod.yml dựng sẵn nó từ
# .env ở thư mục gốc (POSTGRES_USER / POSTGRES_PASSWORD / POSTGRES_DB),
# để mật khẩu DB chỉ tồn tại ở một file duy nhất. Xem .env.example ở gốc.

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_HOURS=8

# Access token nằm trong cookie HttpOnly (JS không đọc được).
# true  = cookie chỉ gửi qua HTTPS. BẮT BUỘC ở prod.
# false = chỉ dùng khi dev trên http://localhost.
COOKIE_SECURE=true

# production = tắt /docs, /redoc, /openapi.json (không phơi API cho người lạ).
# Đặt development nếu cần mở Swagger để debug.
# Bỏ trống thì mặc định là production.
ENVIRONMENT=production

# Ghi đè nếu cần. "lax" chống CSRF cho POST/PATCH/DELETE
# và vẫn cho phép redirect OAuth từ Google set cookie.
# COOKIE_SAMESITE=lax
# ACCESS_TOKEN_COOKIE_NAME=access_token
